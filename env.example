# ============================================
# MedAI Frontend Configuration
# ============================================

# API Configuration (REQUIRED)
# Backend API base URL
VITE_API_BASE_URL=http://localhost:8000/api/v1

# Application Settings
VITE_APP_TITLE=MedAI - Medical Consultation System
VITE_APP_VERSION=2.0.0
VITE_APP_DESCRIPTION=Multi-Agent AI Medical Consultation with Ethiopian Healthcare Integration

# Map Configuration
# OpenStreetMap (free) - no API key needed
VITE_MAP_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png
VITE_MAP_ATTRIBUTION='&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors'

# Google Maps (optional - if you want to use Google Maps later)
# VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Language Settings
VITE_DEFAULT_LANGUAGE=en
VITE_SUPPORTED_LANGUAGES=en,am

# Feature Flags
VITE_ENABLE_VOICE=true
VITE_ENABLE_OFFLINE_MODE=true
VITE_ENABLE_PWA=true
VITE_ENABLE_ANALYTICS=false

# Development Settings
VITE_DEBUG=true
VITE_LOG_LEVEL=info

# Performance
VITE_API_TIMEOUT=30000  # 30 seconds
VITE_MAX_UPLOAD_SIZE=10485760  # 10MB

# Emergency Settings
VITE_EMERGENCY_PHONE=911
VITE_EMERGENCY_EMAIL=support@medai.health

# Ethiopian Specific
VITE_COUNTRY_CODE=ET
VITE_CURRENCY=ETB
VITE_TIMEZONE=Africa/Addis_Ababa

# ============================================
# Production Settings (uncomment for production)
# ============================================

# VITE_API_BASE_URL=https://api.medai.health/api/v1
# VITE_DEBUG=false
# VITE_ENABLE_ANALYTICS=true

# Analytics (optional)
# VITE_GOOGLE_ANALYTICS_ID=UA-XXXXXXXXX-X
# VITE_SENTRY_DSN=your_sentry_dsn_here